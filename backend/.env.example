#   - ai     AI??????Wiki?????????(??)
#   - auto   Wiki?????????????AI,??????????AI??
QA_RETRIEVAL_MODE=ai

# QA_AI_DIRECT_THRESHOLD: auto???,Wiki????????????????AI
# ?????,?????????????,?????AI??
QA_AI_DIRECT_THRESHOLD=200
# ============================================
# ????
