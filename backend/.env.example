# ============================================
# LLM 供应商配置
# ============================================
# LLM_PROVIDER: 选择使用哪个LLM供应商
#   - openai      使用 OpenAI API (GPT系列)
#   - anthropic   使用 Anthropic API (Claude系列)
LLM_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic 配置
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514

# ============================================
# 向量搜索配置
# ============================================
# ENABLE_VECTOR_SEARCH: 是否启用向量语义搜索
#   - true   启用（需要配置LLM API以获取embedding）
#   - false  仅使用关键词搜索（无需LLM API，零成本）
ENABLE_VECTOR_SEARCH=true

# 向量参数
VECTOR_DIM=1536
TOP_K=5

# ============================================
# 问答检索模式配置
# ============================================
# QA_RETRIEVAL_MODE: /api/ai/ask 的默认检索模式
#   - ai     AI理解问题后从Wiki目录中选取相关条目（推荐）
#   - auto   Wiki页面数低于阈值时直接全部给AI，超过则先关键词预筛再AI精选
QA_RETRIEVAL_MODE=ai

# QA_AI_DIRECT_THRESHOLD: auto模式下，Wiki页面数低于此值时直接把全部条目给AI
# 超过此值时，先用关键词搜索预筛一批候选，再把候选给AI精选
QA_AI_DIRECT_THRESHOLD=200
# ============================================
# 应用配置
# ============================================
APP_NAME=LLM Wiki Service
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# 数据存储路径
# ============================================
DATA_DIR=./data
RAW_DIR=./data/raw
WIKI_DIR=./data/wiki

# ============================================
# Git 同步配置
# ============================================
# GIT_SYNC_ENABLED: 是否启用定时Git同步
GIT_SYNC_ENABLED=false

# GIT_SYNC_INTERVAL_MINUTES: 同步间隔（分钟）
GIT_SYNC_INTERVAL_MINUTES=30

# GIT_REPO_PATH: 需要同步的本地目录路径（通常是data目录）
GIT_REPO_PATH=./data

# GIT_REMOTE_URL: Git远程仓库地址
GIT_REMOTE_URL=

# GIT_USER_NAME: Git提交用户名
GIT_USER_NAME=LLM Wiki Bot

# GIT_USER_EMAIL: Git提交邮箱
GIT_USER_EMAIL=llm-wiki-service-demo-bot@example.com

# GIT_BRANCH: 推送的分支名
GIT_BRANCH=main

# GIT_COMMIT_MESSAGE: 提交信息（留空则自动生成）
GIT_COMMIT_MESSAGE=

# ============================================
# 服务配置
# ============================================
HOST=0.0.0.0
PORT=8000
